menu "ESP Emote Graphics Framework"

    menu "Display"

        config GFX_DISP_INV_BUF_SIZE
            int "Maximum dirty areas per display"
            range 8 64
            default 32
            help
                Maximum number of dirty (invalidated) rectangles tracked per
                display in a single frame. Each object move / update adds one
                entry; overlapping areas are merged during refresh.

                Increase if complex scenes with many independently moving
                objects cause "inv_buf overflow" warnings. Decrease to save
                a small amount of RAM on simple UIs.

    endmenu

    menu "Font"

        config GFX_FONT_FREETYPE_SUPPORT
            bool "Enable FreeType font support"
            default n
            help
                Enable support for FreeType fonts (TTF/OTF).
                This requires the FreeType library to be enabled.

                When enabled, you can use TrueType and OpenType fonts.
                When disabled, only LVGL C format fonts are supported.

        menu "Glyph Cache"

            config GFX_LABEL_GLYPH_CACHE_MAX_ENTRIES
                int "Maximum cached glyph entries per font"
                range 8 512
                default 64
                help
                    Maximum number of glyph records retained in the shared glyph cache
                    for a single font adapter.

            config GFX_LABEL_GLYPH_CACHE_MAX_BITMAP_BYTES
                int "Maximum glyph cache bitmap bytes per font"
                range 1024 131072
                default 12288
                help
                    Upper memory budget, in bytes, for cached glyph alpha bitmaps and
                    atlas pages owned by a single font adapter cache.

            config GFX_LABEL_GLYPH_ATLAS_PAGE_BYTES
                int "Glyph atlas page size"
                range 256 8192
                default 1024
                help
                    Minimum allocation unit, in bytes, for glyph atlas pages. Larger
                    values reduce allocation frequency but increase retained memory.

        endmenu

    endmenu

    menu "EAF (Emote Animation Format)"

        config GFX_EAF_JPEG_DECODE_SUPPORT
            bool "Enable JPEG decoding support"
            default y
            help
                Enable support for JPEG decoding in EAF (Emote Animation Format).
                This requires the ESP JPEG decoder component to be enabled.

                When enabled, EAF files can use JPEG encoding for image blocks.
                When disabled, JPEG encoding will not be available, reducing code size.

        config GFX_EAF_HEATSHRINK_SUPPORT
            bool "Enable Heatshrink support"
            default y
            depends on HEATSHRINK_DYNAMIC_ALLOC || (HEATSHRINK_STATIC_WINDOW_BITS = 8 && HEATSHRINK_STATIC_LOOKAHEAD_BITS = 4)
            help
                Enable support for Heatshrink decoding in EAF (Emote Animation Format).

                Note: Only supports 8-bit window and 4-bit lookahead if dynamic allocation is disabled.

        comment "Heatshrink support is unavailable due to static bit mismatch"
            depends on !HEATSHRINK_DYNAMIC_ALLOC && (HEATSHRINK_STATIC_WINDOW_BITS != 8 || HEATSHRINK_STATIC_LOOKAHEAD_BITS != 4)

    endmenu

    menu "Mesh & software triangle blend"

        choice GFX_MESH_SUBPIXEL_PRECISION
            prompt "Mesh / triangle vertex subpixel precision"
            default GFX_MESH_SUBPIXEL_Q8
            help
                Fractional bits for mesh coordinates (x_q8/y_q8 fields) and for
                gfx_sw_blend_img_triangle_draw. Q8 gives finer silhouettes; Q4
                uses coarser subpixel steps. Must be consistent for the whole build.

            config GFX_MESH_SUBPIXEL_Q4
                bool "Q4 (4 fractional bits, 16 steps per pixel)"

            config GFX_MESH_SUBPIXEL_Q8
                bool "Q8 (8 fractional bits, 256 steps per pixel)"
        endchoice

        config GFX_BLEND_TRI_EDGE_AA_RANGE
            int "Triangle edge AA range (subpixel units; 0 = one logical pixel)"
            default 0
            range 0 4096
            help
                Outer-edge anti-alias distance threshold in the same fixed-point
                units as mesh vertices. 0 selects one logical pixel (1 << fractional bits).
                Increase for a wider AA feather (softer edges, more outer pixels).

    endmenu

    menu "Face Emote"

        config GFX_FACE_EMOTE_DEFAULT_TIMER_PERIOD_MS
            int "Default animation timer period (ms)"
            range 1 1000
            default 33
            help
                Default timer period used by gfx_face_emote_cfg_init().
                Smaller values animate more smoothly but wake the CPU more often.

        config GFX_FACE_EMOTE_DEFAULT_EYE_SEGS
            int "Default eye Bezier segments"
            range 4 64
            default 24
            help
                Default number of segments per eye cubic fill edge.
                Increase for smoother contours at the cost of more mesh work.

        config GFX_FACE_EMOTE_DEFAULT_BROW_SEGS
            int "Default brow Bezier segments"
            range 4 64
            default 32
            help
                Default number of segments per eyebrow stroke.

        config GFX_FACE_EMOTE_DEFAULT_MOUTH_SEGS
            int "Default mouth Bezier segments"
            range 4 64
            default 32
            help
                Default number of segments per mouth cubic stroke half.

        config GFX_FACE_EMOTE_CREATE_FALLBACK_RES
            int "Fallback display resolution"
            range 1 4096
            default 360
            help
                Resolution used by gfx_face_emote_create() when the display
                reports 0 for width or height.

        config GFX_FACE_EMOTE_MAX_STROKE_SEGS
            int "Maximum compiled stroke segments"
            range 8 256
            default 128
            help
                Upper bound for compiled stack buffers used by Bezier stroke
                tessellation. Must be >= the largest runtime stroke segment count.

        config GFX_FACE_EMOTE_MAX_FILL_SEGS
            int "Maximum compiled fill segments"
            range 8 128
            default 64
            help
                Upper bound for compiled stack buffers used by Bezier fill
                tessellation. Must be >= the largest runtime fill segment count.

    endmenu

endmenu
